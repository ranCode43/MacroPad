{
    "keyboard_name": "Hackpad3",
    "manufacturer": "custom",
    "url": "https://github.com/rocks/hackpad3",
    "maintainer": "you",
    "usb": {
        "vid": "0xFEED",
        "pid": "0x0003",
        "device_version": "1.0.0"
    },
    "processor": "RP2040",
