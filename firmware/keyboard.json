            ["GP2", "GP4", "GP3"]
        ]
    },
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "nkro": true
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0}
            ]
        }
    }
}
